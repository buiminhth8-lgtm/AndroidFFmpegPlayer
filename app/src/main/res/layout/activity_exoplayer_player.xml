<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/exoplayer_player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/exoplayer_stats_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#99000000"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:text="state=idle"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_gravity="bottom"
        android:background="#CCFFFFFF"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <EditText
                android:id="@+id/exoplayer_source_edit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="rtsp / rtmp / hls / http / file source"
                android:inputType="textUri"
                android:singleLine="true"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Switch
                    android:id="@+id/exoplayer_low_latency_switch"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Low Latency"
                    android:textColor="@color/black" />

                <Switch
                    android:id="@+id/exoplayer_rtsp_tcp_switch"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="RTSP TCP"
                    android:textColor="@color/black" />

                <Switch
                    android:id="@+id/exoplayer_mute_switch"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Mute"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/exoplayer_start_button"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Start" />

                <Button
                    android:id="@+id/exoplayer_stop_button"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Stop" />

                <Button
                    android:id="@+id/exoplayer_info_button"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Info" />

                <Button
                    android:id="@+id/exoplayer_clear_log_button"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Clear" />
            </LinearLayout>

            <Button
                android:id="@+id/exoplayer_native_fallback_button"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Open Native FFmpeg" />

            <TextView
                android:id="@+id/exoplayer_log_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#111827"
                android:fontFamily="monospace"
                android:minHeight="130dp"
                android:padding="10dp"
                android:textColor="#E5E7EB"
                android:textIsSelectable="true"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
